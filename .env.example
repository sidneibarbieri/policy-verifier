# Optional local rerun credentials.
# Copy this file to `.env` only if you want to execute paid LLM calls yourself.
# The zero-cost reviewer path does not require any of these variables.

# Common controls
SOC_LLM_PROVIDER=openai
SOC_LLM_MAX_RETRIES=1
SOC_LLM_RETRY_WAIT_SECONDS=0

# OpenAI example
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic example
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_BASE=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01

# Azure OpenAI example
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
